wandb/
data/
eda/out/

# One dir per run (runs/<run>/): ignore the heavy, regenerable artifacts —
# checkpoints, gen dumps, metrics, BFCL result/detail JSONs. The small BFCL
# summary CSVs (runs/<run>/bfcl/scores/data_*.csv) stay tracked.
runs/*/train/
runs/*/eval/
runs/*/bfcl/results/
runs/*/bfcl/scores/*/
runs/*/merged/       # merged bf16 model — regenerable from the adapter via tool_forge.merge
runs/*/*.log         # run logs (train/generate/merge stdout)

# env
.env
.vscode

# Markdown files used for goal setting
CLAUDE.md
COURSE_LOG.md
